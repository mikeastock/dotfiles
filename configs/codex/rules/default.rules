prefix_rule(
    pattern = ["terraform", "apply"],
    decision = "prompt",
    justification = "terraform apply can modify infrastructure.",
    match = [
        ["terraform", "apply"],
        ["terraform", "apply", "-auto-approve"],
        "terraform apply",
        "terraform apply -auto-approve",
    ],
)

prefix_rule(
    pattern = ["tf", "apply"],
    decision = "prompt",
    justification = "tf apply can modify infrastructure.",
    match = [
        ["tf", "apply"],
        ["tf", "apply", "-auto-approve"],
        "tf apply",
        "tf apply -auto-approve",
    ],
)

prefix_rule(
    pattern = ["terraform", "-chdir=regions/us-west-2-lax-devbox", "apply"],
    decision = "prompt",
    justification = "terraform apply can modify infrastructure.",
    match = [
        ["terraform", "-chdir=regions/us-west-2-lax-devbox", "apply", "plan.tfplan"],
    ],
)

prefix_rule(
    pattern = ["mise", ["run", "exec"], "terraform", "--", "apply"],
    decision = "prompt",
    justification = "terraform apply can modify infrastructure.",
    match = [
        ["mise", "run", "terraform", "--", "apply", "plan.tfplan"],
        ["mise", "run", "terraform", "--", "apply", "tmp/taildrive.tfplan"],
        ["mise", "exec", "terraform", "--", "apply", "plan.tfplan"],
    ],
)

prefix_rule(
    pattern = [
        "mise",
        ["run", "exec"],
        "terraform",
        "--",
        "-chdir=regions/us-west-2-lax-devbox",
        "apply",
    ],
    decision = "prompt",
    justification = "terraform apply can modify infrastructure.",
    match = [
        [
            "mise",
            "run",
            "terraform",
            "--",
            "-chdir=regions/us-west-2-lax-devbox",
            "apply",
            "plan.tfplan",
        ],
    ],
)

prefix_rule(
    pattern = ["mise", ["run", "exec"], "terraform", "--", ["terraform", "tf", "tofu"], "apply"],
    decision = "prompt",
    justification = "terraform apply can modify infrastructure.",
    match = [
        ["mise", "exec", "terraform", "--", "terraform", "apply", "plan.tfplan"],
        ["mise", "run", "terraform", "--", "tofu", "apply", "plan.tfplan"],
    ],
)
