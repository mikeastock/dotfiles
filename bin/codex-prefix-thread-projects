#!/usr/bin/env node

const { execFile } = require("node:child_process");
const { existsSync } = require("node:fs");
const os = require("node:os");
const path = require("node:path");

const VERSION = "0.1.0";
const DEFAULT_LIMIT = 100;
const SOURCE_KINDS = [
  "cli",
  "vscode",
  "exec",
  "appServer",
  "subAgent",
  "subAgentReview",
  "subAgentCompact",
  "subAgentThreadSpawn",
  "subAgentOther",
  "unknown",
];
const PROJECT_ABBRS = {
  bizops: "biz",
  "bizops-infra": "b-inf",
  infrastructure: "m-inf",
  dotfiles: "dot",
  scratchpad: "sp",
  marketing: "mkt",
  "release-notes": "rel",
  "internal-release-notes": "irn",
  worktree: "wkt",
  app: "a1",
  app2: "a2",
  app3: "a3",
  app4: "a4",
  app5: "a5",
  app6: "a6",
};

class UsageError extends Error {}

function main(argv) {
  run(argv).catch(error => {
    if (error instanceof UsageError) {
      console.error(error.message);
      console.error("Run `codex-prefix-thread-projects --help` for usage.");
      process.exitCode = 2;
      return;
    }

    console.error(error.message);
    process.exitCode = 1;
  });
}

async function run(argv) {
  const options = parseArgs(argv);

  if (options.help) {
    printHelp();
    return;
  }

  if (options.version) {
    console.log(VERSION);
    return;
  }

  const threads = await listAllThreads(options);
  const changes = await plannedChanges(threads);
  const renamed = [];
  const failures = [];

  for (const change of changes) {
    if (options.dryRun) continue;

    try {
      await codexAppctlRpc("thread/name/set", {
        name: change.nextName,
        threadId: change.threadId,
      });
      renamed.push(change);
    } catch (error) {
      failures.push({
        ...change,
        error: error.message,
      });
    }
  }

  printReport({
    changes: options.dryRun ? changes : renamed,
    dryRun: options.dryRun,
    failures,
    json: options.json,
  });
}

function parseArgs(argv) {
  const options = {
    dryRun: false,
    json: false,
    help: false,
    version: false,
    limit: DEFAULT_LIMIT,
    includeArchived: true,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];

    if (arg === "-h" || arg === "--help") options.help = true;
    else if (arg === "--version") options.version = true;
    else if (arg === "--dry-run") options.dryRun = true;
    else if (arg === "--json") options.json = true;
    else if (arg === "--active-only") options.includeArchived = false;
    else if (arg === "--limit") options.limit = parseLimit(takeValue(argv, ++i, arg));
    else throw new UsageError(`Unknown option: ${arg}`);
  }

  return options;
}

async function listAllThreads(options) {
  const active = await listThreadPages({ ...options, archived: false });
  if (!options.includeArchived) return active;

  const archived = await listThreadPages({ ...options, archived: true });
  return [...active, ...archived];
}

async function listThreadPages({ limit, archived }) {
  const threads = [];
  let cursor = null;

  while (true) {
    const params = {
      archived,
      limit,
      sourceKinds: SOURCE_KINDS,
    };
    if (cursor) params.cursor = cursor;

    const result = await codexAppctlRpc("thread/list", params);
    threads.push(...result.data);

    if (!result.nextCursor) return threads;
    cursor = result.nextCursor;
  }
}

async function plannedChanges(threads) {
  const changes = [];

  for (const thread of dedupeThreads(threads)) {
    if (thread.path && !existsSync(thread.path)) continue;

    const project = projectKey(thread);
    const abbr = projectAbbr(thread);
    const omitPrefix = shouldOmitPrefix(thread, project);
    if (!abbr && !omitPrefix) continue;

    const currentName = displayName(thread);
    if (!currentName) continue;

    const aliases = projectPrefixAliases(thread, project);
    const nextName = omitPrefix
      ? unprefixedName(currentName, aliases)
      : prefixedName(currentName, abbr, { aliases });
    if (nextName === currentName) continue;

    changes.push({
      threadId: thread.id,
      cwd: thread.cwd,
      project,
      abbr,
      previousName: currentName,
      nextName,
    });
  }

  return changes;
}

function dedupeThreads(threads) {
  const seen = new Set();
  const result = [];

  for (const thread of threads) {
    if (seen.has(thread.id)) continue;

    seen.add(thread.id);
    result.push(thread);
  }

  return result;
}

function projectAbbr(thread) {
  const project = projectKey(thread);
  if (!project) return null;

  return PROJECT_ABBRS[project] || project;
}

function projectKey(thread) {
  if (!thread.cwd) return null;

  const cwd = path.resolve(thread.cwd);
  const basename = path.basename(cwd);

  if (isBuildrAppWorktree(cwd)) return "worktree";

  return basename || null;
}

function shouldOmitPrefix(thread, project) {
  if (!thread.cwd) return false;

  const cwd = path.resolve(thread.cwd);
  return project === "worktree" || cwd === codeRoot();
}

function isBuildrAppWorktree(cwd) {
  const buildrRoot = path.resolve("/data/workspace/code/buildr");
  const codexHome = path.resolve(os.homedir(), ".codex");
  const basename = path.basename(cwd);
  const parent = path.dirname(cwd);

  if (parent === buildrRoot && /^app-.+/.test(basename)) return true;
  if (basename === "app" && cwd.startsWith(`${buildrRoot}/worktrees/`)) return true;
  if (basename === "app" && cwd.startsWith(`${codexHome}/worktrees/`)) return true;

  return false;
}

function codeRoot() {
  return path.resolve("/data/workspace/code");
}

function projectPrefixAliases(thread, project) {
  if (!thread.cwd) return [];

  const cwd = path.resolve(thread.cwd);
  const aliases = [
    path.basename(cwd),
    project,
  ];

  if (project === "worktree") {
    aliases.push("app", "a1", "worktree", "wkt", path.basename(path.dirname(cwd)));
  }

  if (cwd === codeRoot()) aliases.push("code");

  return [...new Set(aliases.filter(Boolean))];
}

function displayName(thread) {
  if (thread.name) return oneLine(thread.name);
  if (thread.preview) return oneLine(thread.preview);
  return null;
}

function prefixedName(name, abbr, { aliases = [] } = {}) {
  const initialParsed = parseKnownPrefix(name, abbr, aliases);
  const oldMerged = /^MERGED:\s+(.+)$/.exec(initialParsed?.body || name);
  const parsed = oldMerged ? parseKnownPrefix(oldMerged[1], abbr, aliases) || initialParsed : initialParsed;
  const body = oldMerged ? parsed?.body || oldMerged[1] : parsed?.body || name;
  const alreadyCanonical = parsed?.prefix === abbr && parsed.prefixes.length === 1 && !oldMerged;

  if (alreadyCanonical && !parsed.merged) return name;

  return `${abbr}: ${body}`;
}

function unprefixedName(name, aliases = []) {
  const initialParsed = parseKnownPrefix(name, null, aliases);
  const oldMerged = /^MERGED:\s+(.+)$/.exec(initialParsed?.body || name);
  const parsed = oldMerged ? parseKnownPrefix(oldMerged[1], null, aliases) || initialParsed : initialParsed;

  if (oldMerged) return parsed?.body || oldMerged[1];
  if (parsed) return parsed.body;

  return name;
}

function parseKnownPrefix(name, currentPrefix, aliases = []) {
  const prefixes = [];
  let body = name;
  let merged = false;

  while (true) {
    const parsed = parseOneKnownPrefix(body, currentPrefix, aliases);
    if (!parsed) break;

    prefixes.push({
      merged: parsed.merged,
      prefix: parsed.prefix,
    });
    merged ||= parsed.merged;
    body = parsed.body;
  }

  if (prefixes.length === 0) return null;

  return {
    body,
    merged,
    prefix: prefixes[0].prefix,
    prefixes,
  };
}

function parseOneKnownPrefix(name, currentPrefix, aliases = []) {
  const knownPrefixes = new Set([
    ...Object.values(PROJECT_ABBRS),
    ...Object.keys(PROJECT_ABBRS),
    ...aliases,
    currentPrefix,
  ].filter(Boolean));

  for (const prefix of knownPrefixes) {
    const mergedPrefix = `${prefix}(merged): `;
    if (name.startsWith(mergedPrefix)) {
      return {
        body: name.slice(mergedPrefix.length),
        merged: true,
        prefix,
      };
    }

    const plainPrefix = `${prefix}: `;
    if (name.startsWith(plainPrefix)) {
      return {
        body: name.slice(plainPrefix.length),
        merged: false,
        prefix,
      };
    }
  }

  return null;
}

function oneLine(value) {
  return value.replace(/\s+/g, " ").trim();
}

function codexAppctlRpc(method, params) {
  return new Promise((resolve, reject) => {
    execFile(codexAppctlPath(), [
      "rpc",
      method,
      JSON.stringify(params),
    ], { maxBuffer: 50 * 1024 * 1024 }, (error, stdout, stderr) => {
      if (error) {
        const message = stderr.trim() || error.message;
        reject(new Error(message));
        return;
      }

      try {
        resolve(JSON.parse(stdout));
      } catch (parseError) {
        reject(new Error(`Invalid codex-appctl JSON: ${parseError.message}`));
      }
    });
  });
}

function codexAppctlPath() {
  if (process.env.CODEX_APPCTL_BIN) return process.env.CODEX_APPCTL_BIN;
  return path.join(__dirname, "codex-appctl");
}

function printReport({ changes, dryRun, failures, json }) {
  if (json) {
    console.log(JSON.stringify({ dryRun, changes, failures }, null, 2));
    return;
  }

  if (changes.length === 0 && failures.length === 0) {
    console.log("No thread names need project prefixes.");
    return;
  }

  const verb = dryRun ? "would rename" : "renamed";
  for (const change of changes) {
    console.log(`${verb}: ${change.threadId}`);
    console.log(`  ${change.previousName}`);
    console.log(`  -> ${change.nextName}`);
  }

  for (const failure of failures) {
    console.log(`failed: ${failure.threadId}`);
    console.log(`  ${failure.previousName}`);
    console.log(`  -> ${failure.nextName}`);
    console.log(`  error: ${failure.error}`);
  }
}

function takeValue(argv, index, flag) {
  const value = argv[index];
  if (!value || value.startsWith("--")) {
    throw new UsageError(`Missing value for ${flag}.`);
  }
  return value;
}

function parseLimit(value) {
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed < 1) {
    throw new UsageError("--limit must be a positive integer.");
  }
  return parsed;
}

function printHelp() {
  console.log(`codex-prefix-thread-projects ${VERSION}

Usage:
  codex-prefix-thread-projects [options]

Renames saved Codex threads so each name starts with the project abbreviation
derived from the thread cwd basename, e.g. app6 -> a6:.

Options:
  --dry-run       Preview changes without renaming
  --json          Print a machine-readable report
  --active-only   Skip archived threads
  --limit <n>     Page size for Codex thread listing (default: ${DEFAULT_LIMIT})
  --version       Print version
  -h, --help      Show help

Environment:
  CODEX_APPCTL_BIN  Path to codex-appctl
`);
}

main(process.argv.slice(2));
