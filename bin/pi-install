#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"

  while [[ -L "$source_path" ]]; do
    local source_dir
    source_dir="$(cd "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done

  cd "$(dirname "$source_path")" && pwd
}

SCRIPT_DIR="$(resolve_script_path)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/pi-paths.sh"

PATCH_SCRIPT="${PI_PATCH_SCRIPT:-$REPO_ROOT/configs/pi-patch/apply-pi-ghostty-tmux-image-patch.sh}"

current_version() {
  local pkg="$PI_ROOT/package.json"

  if [[ -f "$pkg" ]]; then
    node -e "console.log(require('$pkg').version)"
  else
    echo "unknown"
  fi
}

require_command() {
  local name="$1"

  if ! command -v "$name" >/dev/null 2>&1; then
    echo "Missing required command: $name" >&2
    exit 1
  fi
}

require_file() {
  local path="$1"

  if [[ ! -f "$path" ]]; then
    echo "Missing required file: $path" >&2
    exit 1
  fi
}

main() {
  require_command npm
  require_command make
  require_file "$PATCH_SCRIPT"

  local old_version
  old_version="$(current_version)"

  npm install -g --prefix "$PI_PREFIX" @mariozechner/pi-coding-agent

  if [[ ! -d "$PI_ROOT" ]]; then
    echo "Canonical Pi install missing after npm install: $PI_ROOT" >&2
    exit 1
  fi

  if [[ ! -x "$PI_BIN" ]]; then
    echo "Canonical Pi launcher missing after npm install: $PI_BIN" >&2
    exit 1
  fi

  (
    cd "$REPO_ROOT"
    make install-configs
  )

  "$PATCH_SCRIPT" "$PI_ROOT"

  local new_version
  new_version="$(current_version)"

  if [[ "$old_version" == "unknown" ]]; then
    echo "Pi installed: $new_version"
  elif [[ "$old_version" == "$new_version" ]]; then
    echo "Pi up to date: $new_version"
  else
    echo "Pi updated: $old_version → $new_version"
  fi
}

main "$@"
