{
  "name": "agents",
  "private": true,
  "description": "Reusable skills and extensions for AI coding agents",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:extensions": "node --import tsx --test pi-extensions/handoff/index.test.ts pi-extensions/openai-fast/config.test.ts pi-extensions/openai-fast/index.test.ts",
    "amp:plugin-types": "python3 scripts/update_amp_plugin_types.py",
    "amp:plugin-check": "pnpm amp:plugin-types && tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^26.1.1",
    "openai": "^6.46.0",
    "p-limit": "^7.3.0",
    "tsx": "^4.23.0",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2"
  }
}
